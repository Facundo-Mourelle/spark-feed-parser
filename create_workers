#!/bin/bash

# Script: create_workers
# Propósito: Crear y configurar workers para Spark Standalone cluster
# Uso: ./create_workers <number_of_workers>

set -e  # Salir en caso de error

# Verificar argumentos
if [ $# -ne 1 ]; then
    echo "Uso: $0 <number_of_workers>"
    echo "Ejemplo: $0 4"
    exit 1
fi

NUM_WORKERS=$1

# Validar que el número sea positivo
if ! [[ "$NUM_WORKERS" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: El número de workers debe ser un entero positivo"
    exit 1
fi

# Configuración
SPARK_HOME=${SPARK_HOME:-"/opt/spark"}
MASTER_HOST=${MASTER_HOST:-"localhost"}
MASTER_PORT=${MASTER_PORT:-"7077"}
WORKER_BASE_PORT=${WORKER_BASE_PORT:-"7078"}
WORKER_WEBUI_BASE_PORT=${WORKER_WEBUI_BASE_PORT:-"8081"}

# Archivos de configuración
WORKERS_FILE="$SPARK_HOME/conf/workers"
SPARK_ENV_FILE="$SPARK_HOME/conf/spark-env.sh"

echo "=== Configurando Spark Standalone Cluster ==="
echo "Número de workers: $NUM_WORKERS"
echo "Spark Home: $SPARK_HOME"
echo "Master: spark://$MASTER_HOST:$MASTER_PORT"

# Verificar que Spark esté instalado
if [ ! -d "$SPARK_HOME" ]; then
    echo "Error: Spark no encontrado en $SPARK_HOME"
    echo "Configura la variable SPARK_HOME correctamente"
    exit 1
fi

# Crear archivo de configuración de workers
echo "Configurando workers..."
cat > "$WORKERS_FILE" << EOF
# Worker nodes for Spark Standalone cluster
# Generated by create_workers script
EOF

# Generar configuración para workers locales
for i in $(seq 1 $NUM_WORKERS); do
    echo "localhost" >> "$WORKERS_FILE"
done

# Configurar spark-env.sh si no existe
if [ ! -f "$SPARK_ENV_FILE" ]; then
    cp "$SPARK_HOME/conf/spark-env.sh.template" "$SPARK_ENV_FILE"
fi

# Configurar variables de entorno para el cluster
cat >> "$SPARK_ENV_FILE" << EOF

# Configuration added by create_workers script
export SPARK_MASTER_HOST=$MASTER_HOST
export SPARK_MASTER_PORT=$MASTER_PORT
export SPARK_WORKER_INSTANCES=$NUM_WORKERS
export SPARK_WORKER_CORES=1
export SPARK_WORKER_MEMORY=1g
export SPARK_WORKER_PORT=$WORKER_BASE_PORT
export SPARK_WORKER_WEBUI_PORT=$WORKER_WEBUI_BASE_PORT
EOF

# Función para limpiar procesos anteriores
cleanup_spark() {
    echo "Limpiando procesos Spark anteriores..."
    pkill -f "org.apache.spark" 2>/dev/null || true
    sleep 2
}

# Función para iniciar el master
start_master() {
    echo "Iniciando Spark Master..."
    $SPARK_HOME/sbin/start-master.sh
    sleep 3

    # Verificar que el master esté ejecutándose
    if ! pgrep -f "org.apache.spark.deploy.master.Master" > /dev/null; then
        echo "Error: No se pudo iniciar el Spark Master"
        exit 1
    fi
    echo "✓ Spark Master iniciado en spark://$MASTER_HOST:$MASTER_PORT"
}

# Función para iniciar workers
start_workers() {
    echo "Iniciando $NUM_WORKERS workers..."

    for i in $(seq 1 $NUM_WORKERS); do
        WORKER_PORT=$((WORKER_BASE_PORT + i - 1))
        WEBUI_PORT=$((WORKER_WEBUI_BASE_PORT + i - 1))

        echo "Iniciando worker $i en puerto $WORKER_PORT..."

        $SPARK_HOME/sbin/start-worker.sh \
            spark://$MASTER_HOST:$MASTER_PORT \
            --port $WORKER_PORT \
            --webui-port $WEBUI_PORT \
            --cores 1 \
            --memory 1g &

        sleep 1
    done

    # Esperar a que todos los workers se conecten
    sleep 5

    # Verificar workers
    ACTIVE_WORKERS=$(pgrep -f "org.apache.spark.deploy.worker.Worker" | wc -l)
    echo "✓ $ACTIVE_WORKERS/$NUM_WORKERS workers iniciados"
}

# Función para mostrar el estado del cluster
show_status() {
    echo ""
    echo "=== Estado del Cluster Spark ==="
    echo "Master Web UI: http://$MASTER_HOST:8080"
    echo "Master URL: spark://$MASTER_HOST:$MASTER_PORT"
    echo ""
    echo "Workers activos:"
    pgrep -f "org.apache.spark.deploy.worker.Worker" || echo "No hay workers ejecutándose"
    echo ""
    echo "Para conectar tu aplicación, usa:"
    echo "  .setMaster(\"spark://$MASTER_HOST:$MASTER_PORT\")"
}

# Función principal
main() {
    cleanup_spark
    start_master
    start_workers
    show_status

    echo ""
    echo "✓ Cluster Spark configurado exitosamente con $NUM_WORKERS workers"
    echo ""
    echo "Para detener el cluster, ejecuta:"
    echo "  $SPARK_HOME/sbin/stop-all.sh"
}

# Ejecutar función principal
main
